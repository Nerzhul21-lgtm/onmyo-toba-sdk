# Onmyō Toba SDK — Environment Variables
# Copy this file to .env and fill in your values

# Network: 'testnet' or 'mainnet'
ONMYO_NETWORK=testnet

# Your bot wallet mnemonic (12 or 24 words)
# This wallet will place bets — keep it secret, never commit to git
ONMYO_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# For AuthZ bots only:
# The bot's own mnemonic (signs MsgExec transactions, pays gas)
BOT_MNEMONIC=

# The user's wallet address that the bot trades on behalf of
GRANTER_ADDRESS=inj1...

# For granting AuthZ (run once):
# The user's own mnemonic (to sign the grant)
GRANTER_MNEMONIC=

# The bot wallet address to grant permission to
GRANTEE_ADDRESS=inj1...
